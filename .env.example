# API Provider Configuration
API_PROVIDER=openai  # 'openai'

# OpenAI-style Configuration (for OpenAI, Azure OpenAI, etc.)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TIMEOUT=60000  # 60 seconds in milliseconds

# Text Model Configuration (OpenAI-style)
# Note: dotenv does not support variable interpolation. You must duplicate the API key value.
TEXT_MODEL_BASE_URL=https://your_path_to_url
TEXT_MODEL_API_KEY=your_openai_api_key_here  # Same as OPENAI_API_KEY (copy the value)
TEXT_MODEL_NAME=your_model_name
TEXT_MODEL_ENABLE_THINKING=false  # Set to 'true' for Qwen thinking models (e.g., qwen3.5-plus)
TEXT_MODEL_TIMEOUT=60000  # Same as OPENAI_TIMEOUT (copy the value)

# Vision Model Configuration (OpenAI-style)
VISION_MODEL_BASE_URL=https://your_path_to_url/v1
VISION_MODEL_API_KEY=your_openai_api_key_here  # Same as OPENAI_API_KEY (copy the value)
VISION_MODEL_NAME=your_model_name
VISION_MODEL_ENABLE_THINKING=false  # Set to 'true' for Qwen thinking models
VISION_MODEL_TIMEOUT=60000  # Same as OPENAI_TIMEOUT (copy the value)

# LaTeX Configuration
LATEX_ENGINE=xelatex
LATEX_TIMEOUT=120000

# Paths
OUTPUT_DIR=./output
TEMP_DIR=./temp
